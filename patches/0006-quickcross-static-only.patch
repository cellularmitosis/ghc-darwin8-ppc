+    -- Build static libraries only (no dynamic .dyn_o variants) to keep the
+    -- PPC/Darwin cross-build feasible: some huge stage1 compiler modules
+    -- (e.g. GHC.Hs.Instances) exceed the 16MB 24-bit r_address field of
+    -- PPC Mach-O scattered relocations when compiled dynamic.  Static
+    -- builds use different reloc encoding and don't hit the limit.
+    -- Profiling re-enabled in v0.10.0 once LLVM-7 r4 shipped the
+    -- BUG-003 fix in llvm-7-darwin-ppc: clang's PPC asm printer no
+    -- longer emits bare `0` syntax for D-form rA=0 mem refs, so the
+    -- RTS profiling C code round-trips through clang's integrated
+    -- assembler.  See docs/sessions/2026-04-29-session-16-profiling/.
+    , libraryWays = pure [vanilla, profiling]
+    , rtsWays     = pure
+                    [ vanilla, threaded, logging, debug
+                    , threadedDebug, threadedLogging
+                    , profiling, threadedProfiling
+                    , debugProfiling, threadedDebugProfiling ] }
 
 quickCrossArgs :: Args
 quickCrossArgs = sourceArgs SourceArgs
