+-- ghc-darwin8-ppc: byte-swap the ResolvedBCO's array contents when host
+-- (the GHC compiler) and target (the iserv interpreter) disagree on
+-- endianness.  Host writes the Word16 instrs / Word64 bitmap / Word64 lits
+-- as raw bytes in HOST endian; on the target we read them in TARGET endian
+-- so each element is byte-swapped.  Reverse it here so the bytecode
+-- interpreter sees the right values.  Recursively swaps nested BCOs
+-- (ResolvedBCOPtrBCO).
+byteSwapResolvedBCO :: ResolvedBCO -> ResolvedBCO
+byteSwapResolvedBCO bco = bco
+  { resolvedBCOIsLE   = isLittleEndian
+  , resolvedBCOInstrs = amap byteSwap16 (resolvedBCOInstrs bco)
+  , resolvedBCOBitmap = amap byteSwap64 (resolvedBCOBitmap bco)
+  , resolvedBCOLits   = amap byteSwap64 (resolvedBCOLits bco)
+  , resolvedBCOPtrs   = fmap byteSwapResolvedBCOPtr (resolvedBCOPtrs bco)
+  }
+
+byteSwapResolvedBCOPtr :: ResolvedBCOPtr -> ResolvedBCOPtr
+byteSwapResolvedBCOPtr (ResolvedBCOPtrBCO sub) = ResolvedBCOPtrBCO (byteSwapResolvedBCO sub)
+byteSwapResolvedBCOPtr p = p
+
 createBCO :: Array Int HValue -> ResolvedBCO -> IO HValue
-createBCO _   ResolvedBCO{..} | resolvedBCOIsLE /= isLittleEndian
-  = throwIO (ErrorCall $
-        unlines [ "The endianness of the ResolvedBCO does not match"
-                , "the systems endianness. Using ghc and iserv in a"
-                , "mixed endianness setup is not supported!"
-                ])
+createBCO arr bco
+  | resolvedBCOIsLE bco /= isLittleEndian = createBCO arr (byteSwapResolvedBCO bco)
