# Downloaded source archives, prebuilt binaries, the GHC source tree itself.
# Anything we can re-fetch should not be committed.
external/
*.tar.bz2
*.tar.gz
*.tar.xz
*.tbz
*.tgz
*.txz
*.pkg
*.dmg
*.zip
*.bz2
*.gz
*.xz

# Build artefacts and DESTDIRs.
build/
build-*/
dist/
dist-*/
destroot/
destroot-*/
_build/

# Editor / OS detritus.
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/

# Logs from background builds we didn't mean to commit.
*.log

# Test battery outputs (regenerated on every run).
tests/bin/
tests/actual/
tests/expected/

# Claude Code session scratch (if any lands here).
.claude/

# Intermediate compiler outputs in test-programs dir.
tests/programs/*.hi
tests/programs/*.o

# Cabal-examples build artifacts.
tests/cabal-examples/*/dist/
tests/cabal-examples/*/.cabal-store/
tests/cabal-examples/*/cabal.project.local
tests/cabal-examples/*/cabal.project.local~
